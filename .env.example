# Get a free NPS API key at https://www.nps.gov/subjects/developer/get-started.htm
# Copy this file to .env and fill in your key
EXPO_PUBLIC_NPS_API_KEY=DEMO_KEY

# Optional: Google Maps API key for Android map tiles
# Without this, Android will use the default map provider
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
